m4_include([package.m4])
m4_include([test_macros.at])

include_test_inputs([esedbexport])
include_test_inputs([esedbinfo])

AT_TEST_HELPER_FN(
  [compare_with_reference],
  [test_profile test_set test_file test_output],
  [Compares test results against a reference],
  [TEST_PROFILE="$1"
  TEST_SET="$2"
  TEST_FILE="$3"
  TEST_RESULTS="$4"
  STATUS=0

  EXPECTED_RESULTS="$abs_srcdir/input/.${TEST_PROFILE}/${TEST_SET}/${TEST_FILE}.gz"
  if test -f "${EXPECTED_RESULTS}"; then
    # zcat on Mac OS requires the input from stdin.
    ${ZCAT} < "${EXPECTED_RESULTS}" | diff "${TEST_RESULTS}" -;
    STATUS=$?
  else
    ${GZIP_COMMAND} "${TEST_RESULTS}"
    mkdir -p "$abs_srcdir/input/.${TEST_PROFILE}/${TEST_SET}"
    mv "${TEST_RESULTS}.gz" "${EXPECTED_RESULTS}"
  fi
  return ${STATUS}
  ])

AT_TEST_HELPER_FN(
  [run_esedbtools_binary],
  [path arguments],
  [Resolves and runs a esedbtools binary],
  [if test -x "$abs_top_builddir/esedbtools/$[]1"; then
    BINARY="$abs_top_builddir/esedbtools/$[]1"
  elif test -x "$abs_top_builddir/esedbtools/$[]1.exe"; then
    # Prevent wine debug messages failing the test.
    WINEDEBUG=-all

    BINARY="$abs_top_builddir/esedbtools/$[]1.exe"
  else
    echo "Missing binary: $[]1"
    exit 127
  fi
  shift

  $BINARY "$[]@"
  ])

AT_TEST_HELPER_FN(
  [run_esedbtools_binary_and_compare_files],
  [tool_name test_profile options_set arguments test_file],
  [Runs a esedbtools binary and compares resulting files against a reference],
  [ESEDBTOOL="$[]1"
  shift
  TEST_PROFILE="$[]1"
  shift
  OPTIONS_SET="$[]1"
  shift
  # Get the last argument.
  for TEST_FILE do :; done

  FILENAME=`basename "${TEST_FILE}"`
  TEST_SET=`dirname "${TEST_FILE}"`
  TEST_SET=`basename "${TEST_SET}"`

  if test "${OPTIONS_SET}" = "."; then
    OUTPUT_FILE="${FILENAME}.log"
  else
    OUTPUT_FILE="${FILENAME}-${OPTIONS_SET}.log"
  fi
  OUTPUT_DIRECTORY="${FILENAME}.export"

  ath_fn_run_esedbtools_binary "${ESEDBTOOL}" "$[]@" > /dev/null
  STATUS=$?

  if test ${STATUS} -eq 0; then
    # md5sum prefixes the output of a filename that contains an escape character with "\"
    find "${OUTPUT_DIRECTORY}" -type f -exec ${MD5SUM} {} \; | sed 's/^\\//' | LC_ALL=C sort -k2,2 -k1,1 > "${OUTPUT_FILE}"

    ath_fn_compare_with_reference "${TEST_PROFILE}" "${TEST_SET}" "${FILENAME}" "${OUTPUT_FILE}"
    STATUS=$?
  fi
  return $STATUS
  ])

AT_TEST_HELPER_FN(
  [run_esedbtools_binary_and_compare_stdout],
  [tool_name test_profile options_set arguments test_file],
  [Runs a esedbtools binary and compares stdout against a reference],
  [ESEDBTOOL="$[]1"
  shift
  TEST_PROFILE="$[]1"
  shift
  OPTIONS_SET="$[]1"
  shift
  # Get the last argument.
  for TEST_FILE do :; done

  FILENAME=`basename "${TEST_FILE}"`
  TEST_SET=`dirname "${TEST_FILE}"`
  TEST_SET=`basename "${TEST_SET}"`

  if test "${OPTIONS_SET}" = "."; then
    OUTPUT_FILE="${FILENAME}.log"
  else
    OUTPUT_FILE="${FILENAME}-${OPTIONS_SET}.log"
  fi
  ath_fn_run_esedbtools_binary "${ESEDBTOOL}" "$[]@" > "${OUTPUT_FILE}"
  STATUS=$?

  if test ${STATUS} -eq 0; then
    # Strip header with version.
    ${SED} -i'~' '1,2d' "${OUTPUT_FILE}"

    ath_fn_compare_with_reference "${TEST_PROFILE}" "${TEST_SET}" "${FILENAME}" "${OUTPUT_FILE}"
    STATUS=$?
  fi
  return $STATUS
  ])

dnl Runs a esedbtool and compares resulting files against a reference
dnl Arguments:
dnl   tool_name
dnl   test_profile
dnl   test_inputs
m4_define([RUN_TEST_ESEDBTOOL_AND_COMPARE_FILES],
  [m4_foreach_w(
    [test_input],
    [$3],
    [m4_define([options_set], m4_normalize(get_test_input_value([test_input], 1)))
    m4_define([test_options], m4_normalize(get_test_input_value([test_input], 2)))
    m4_define([test_file], [_strip(get_test_input_value([test_input], 3))])

    m4_ifblank(options_set, m4_define([options_set], [.]))

    m4_define([sanitized_test_file],
      [m4_translit([test_file], [[],[],[]"'`\], [______])])

    m4_ifblank(
      test_options,
      [m4_define(
        [test_description],
        [$1 with input: 'sanitized_test_file'])],
      [m4_define(
        [test_description],
        [$1 with options: ']test_options[' and input: 'sanitized_test_file'])])

    AT_SETUP(test_description)

    AT_SKIP_IF(
      [test -n "${SKIP_TOOLS_TESTS}" || test -n "${SKIP_TOOLS_END_TO_END_TESTS}"])

    AT_SKIP_IF([test -z "${GZIP_COMMAND}"])
    AT_SKIP_IF([test -z "${SED}"])
    AT_SKIP_IF([test -z "${ZCAT}"])

    TEST_FILE=`ath_fn_resolve_test_file "$abs_srcdir/input/test_file"`

    AT_CHECK(ath_fn_run_esedbtools_binary_and_compare_files $1 $2 "options_set" test_options "${TEST_FILE}")

    AT_CLEANUP])
  ])

dnl Runs a esedbtool and compares stdout against a reference
dnl Arguments:
dnl   tool_name
dnl   test_profile
dnl   test_inputs
m4_define([RUN_TEST_ESEDBTOOL_AND_COMPARE_STDOUT],
  [m4_foreach_w(
    [test_input],
    [$3],
    [m4_define([options_set], m4_normalize(get_test_input_value([test_input], 1)))
    m4_define([test_options], m4_normalize(get_test_input_value([test_input], 2)))
    m4_define([test_file], [_strip(get_test_input_value([test_input], 3))])

    m4_ifblank(options_set, m4_define([options_set], [.]))

    m4_define([sanitized_test_file],
      [m4_translit([test_file], [[],[],[]"'`\], [______])])

    m4_ifblank(
      test_options,
      [m4_define(
        [test_description],
        [$1 with input: 'sanitized_test_file'])],
      [m4_define(
        [test_description],
        [$1 with options: ']test_options[' and input: 'sanitized_test_file'])])

    AT_SETUP(test_description)

    AT_SKIP_IF(
      [test -n "${SKIP_TOOLS_TESTS}" || test -n "${SKIP_TOOLS_END_TO_END_TESTS}"])

    AT_SKIP_IF([test -z "${GZIP_COMMAND}"])
    AT_SKIP_IF([test -z "${SED}"])
    AT_SKIP_IF([test -z "${ZCAT}"])

    TEST_FILE=`ath_fn_resolve_test_file "$abs_srcdir/input/test_file"`

    AT_CHECK(ath_fn_run_esedbtools_binary_and_compare_stdout $1 $2 "options_set" test_options "${TEST_FILE}")

    AT_CLEANUP])
  ])

dnl Wrap m4_define to overwrite AT_TESTSUITE_NAME
m4_define([_M4_DEFINE_HOOK], m4_defn([m4_define]))
m4_define([m4_define],
  [m4_if(
    [$1],
    [AT_TESTSUITE_NAME],
    [_M4_DEFINE_HOOK([$1], [Running tools tests])],
    [_M4_DEFINE_HOOK([$1], [$2])])])

dnl Redefine AS_BOX to remove the "box"
m4_undefine([AS_BOX])
m4_define([AS_BOX], [echo "$1"])

AT_INIT([tools])
AT_COLOR_TESTS

dnl Rewrite AT_SETUP to change the minimum line length
m4_define([AT_SETUP],
  m4_unquote(
    [m4_bpatsubst(
      m4_dquote(m4_defn([AT_SETUP])),
      [47],
      [72])
    ])
  )

SETUP_HELPER_FUNCTIONS

RUN_TEST_BINARIES(
  [SKIP_TOOLS_TESTS],
  [tools_info_handle tools_output tools_signal tools_windows_search_compression])

RUN_TEST_ESEDBTOOL_AND_COMPARE_STDOUT(
  [esedbinfo],
  [esedbinfo],
  test_inputs_esedbinfo)

RUN_TEST_ESEDBTOOL_AND_COMPARE_STDOUT(
  [esedbexport],
  [esedbexport],
  test_inputs_esedbexport)
